# Basic auth username (required)
BASIC_AUTH_USER=operator

# Generate hash with:
# docker run --rm caddy:2 caddy hash-password --plaintext "your-strong-password"
BASIC_AUTH_HASH=$2a$14$replace_with_generated_hash

# Host Ollama endpoint (run Ollama on your Windows host for GPU acceleration)
OLLAMA_HOST=http://host.docker.internal:11434

# Optional model overrides
OLLAMA_MODEL=qwen2.5:7b-instruct
OLLAMA_EMBED_MODEL=mxbai-embed-large

# Optional: stable Cloudflare Tunnel token (only needed for profile "token")
CF_TUNNEL_TOKEN=
